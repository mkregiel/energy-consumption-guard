# Supabase project URL (dashboard → Settings → API)
SUPABASE_URL=###
# Supabase anon/public key (dashboard → Settings → API)
SUPABASE_KEY=###
# Service role key — bypasses RLS for batch cron jobs (dashboard → Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=###
# Shared secret for manual/local cron HTTP calls: Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=###
# Resend transactional email (https://resend.com/api-keys — verified sender domain required)
# RESEND_API_KEY=###
# RESEND_FROM_EMAIL=alarms@yourdomain.com
# Tuya IoT platform credentials (Tuya Developer Console → Cloud → Development)
TUYA_CLIENT_ID=###
TUYA_CLIENT_SECRET=###
# Tuya Open API base URL for your region (EU default below)
TUYA_API_BASE_URL=https://openapi.tuyaeu.com
# Tuya API region code (e.g. eu, us, cn)
TUYA_API_REGION=eu
# OAuth mode: app (Device Data Sharing) or cloud
TUYA_AUTH_MODE=app
# App schema identifier (Tuya console → App)
TUYA_APP_IDENTIFIER=
# Cloud project credentials (when TUYA_AUTH_MODE=cloud)
TUYA_CLOUD_CLIENT_ID=
TUYA_CLOUD_CLIENT_SECRET=

# Local HTTPS OAuth redirect (requires npm run dev:https — see README)
# Must match Tuya Developer Console callback URL exactly.
# TUYA_OAUTH_REDIRECT_URI=https://127.0.0.1:3000/dashboard/tuya/callback
# App Device Data Sharing H5 scope (Tuya console → OAuth 2.0 config)
# TUYA_OAUTH_SCOPE=devicemessage
