{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(npm run *)",
      "Bash(git commit -m ' *)",
      "Bash(git commit *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix . --quiet",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash -c 'npx tsc --noEmit 1>&2'",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "AI_AGENT=1 bash -c 'FILE=$(jq -r .tool_input.file_path) && npx vitest related \"$FILE\" --run'",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
