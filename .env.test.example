SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=test
RESEND_FROM_EMAIL=test@example.com

# Local Supabase instance (npx supabase status) — used by e2e/lib/tuya-cleanup.ts
# to clean up the local DB the dev server actually writes to during e2e runs.
SUPABASE_LOCAL_URL=
SUPABASE_LOCAL_SERVICE_ROLE_KEY=

# E2E (Playwright): TUYA_API_BASE_URL is overridden to the local stub by
# e2e/start-webserver.ts — these placeholders only need to satisfy
# getMissingTuyaConfigKeys().
TUYA_CLIENT_ID=
TUYA_CLIENT_SECRET=
TUYA_API_BASE_URL=
TUYA_API_REGION=
