---
import Layout from "@/layouts/Layout.astro";
import ConsumptionHero from "@/components/consumption/ConsumptionHero";
import ConsumptionReadingsTable from "@/components/consumption/ConsumptionReadingsTable";
import SyncConsumptionButton from "@/components/consumption/SyncConsumptionButton";
import MeterRegistrationForm from "@/components/tuya/MeterRegistrationForm";
import TuyaConnectCard from "@/components/tuya/TuyaConnectCard";
import ConsumptionLimitForm from "@/components/limits/ConsumptionLimitForm";
import { createClient } from "@/lib/supabase";
import { getMeterConsumptionReadings } from "@/lib/services/consumption-query";
import { getUserMeter } from "@/lib/services/meter-service";
import { getUserLimit } from "@/lib/services/limit-service";
import { getLimitWindowPreview } from "@/lib/services/limit-consumption-preview";
import { getTuyaConnectionStatus } from "@/lib/services/tuya-client";
import type { ConsumptionReading } from "@/types";

const { user } = Astro.locals;

const supabase = createClient(Astro.request.headers, Astro.cookies);
const tuyaStatus =
  supabase && user
    ? await getTuyaConnectionStatus(supabase, user.id)
    : { linked: false, accessTokenExpiresAt: null, tuyaUid: null };
const meter = supabase && user ? await getUserMeter(supabase, user.id) : null;
let limit = null;
if (supabase && user) {
  try {
    limit = await getUserLimit(supabase, user.id);
  } catch {
    // silently degrade; limit section hides gracefully
  }
}

let latestReading: ConsumptionReading | null = null;
let readings: ConsumptionReading[] = [];
let consumptionLoadError: string | null = null;

if (supabase && meter) {
  try {
    const consumption = await getMeterConsumptionReadings(supabase, meter.id);
    latestReading = consumption.latestReading;
    readings = consumption.readings;
  } catch {
    consumptionLoadError = "Nie udało się wczytać odczytów. Odśwież stronę lub spróbuj ponownie.";
  }
}

let limitPreview = null;
if (supabase && meter && limit) {
  try {
    limitPreview = await getLimitWindowPreview(supabase, meter.id, limit);
  } catch {
    // silently degrade; preview hidden, form still functional
  }
}

const limitPreviewProps =
  limitPreview && limit
    ? {
        consumptionKwh: limitPreview.consumptionKwh,
        thresholdKwh: limit.threshold_kwh,
        hasReadings: limitPreview.hasReadings,
      }
    : null;
---

<Layout title="Pulpit">
  <div class="bg-cosmic min-h-screen p-4 py-8">
    <div class="mx-auto w-full max-w-lg space-y-6">
      <header class="text-center text-white">
        <h1 class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Pulpit
        </h1>
        <p class="text-blue-100/80">
          Witaj, <span class="font-semibold text-white">{user?.email}</span>
        </p>
      </header>

      <TuyaConnectCard status={tuyaStatus} />

      <ConsumptionLimitForm client:load initialLimit={limit} preview={limitPreviewProps} />

      <div id="meter-registration">
        <MeterRegistrationForm client:load linked={tuyaStatus.linked} meter={meter} />
      </div>

      {
        meter ? (
          <>
            {consumptionLoadError ? (
              <section class="rounded-2xl border border-red-400/30 bg-red-500/10 p-4 text-sm text-red-100" role="alert">
                <p>{consumptionLoadError}</p>
              </section>
            ) : null}
            <ConsumptionHero latestReading={latestReading} meterLabel={meter.label} />
            <ConsumptionReadingsTable readings={readings} />
            <SyncConsumptionButton client:load meterId={meter.id} />
          </>
        ) : (
          <section class="rounded-2xl border border-dashed border-white/15 bg-white/5 p-6 text-center text-sm text-blue-100/50">
            <p class="font-medium text-blue-100/70">Zużycie energii</p>
            <p class="mt-1">Zarejestruj licznik, aby zobaczyć odczyty i uruchomić synchronizację.</p>
          </section>
        )
      }

      <form method="POST" action="/api/auth/signout" class="text-center">
        <button
          type="submit"
          class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm text-white transition-colors hover:bg-white/20"
        >
          Wyloguj
        </button>
      </form>
    </div>
  </div>
</Layout>
